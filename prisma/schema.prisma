datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// 🔐 MODELOS DE AUTENTICAÇÃO (AUTH.JS / NEXTAUTH V5)
// ==========================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  
  accounts      Account[]
  sessions      Session[]
  
  // --- RELACIONAMENTOS DO POKÉPEDRO ---
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  stats         UserStat?
  gameSessions  GameSession[]
  pokemonStats  PokemonStat[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// 🎮 MODELOS DE GAMIFICAÇÃO DO POKÉPEDRO
// ==========================================

// Estatísticas gerais do jogador (Seção: "Meu Progresso")
model UserStat {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  totalGames    Int      @default(0) // Total de partidas jogadas
  totalCorrect  Int      @default(0) // Total de acertos
  totalWrong    Int      @default(0) // Total de erros
  bestStreak    Int      @default(0) // Maior sequência de acertos consecutiva
  currentStreak Int      @default(0) // Sequência atual
  totalTimeMs   BigInt   @default(0) // Soma total de tempo (para calcular tempo médio)
  
  updatedAt     DateTime @updatedAt
}

// Histórico e progresso de uma partida específica
model GameSession {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  region         String    @default("ALL")    // Ex: "KANTO", "JOHTO", "ALL"
  orderType      String    @default("RANDOM") // Ex: "RANDOM", "POKEDEX"
  isCompleted    Boolean   @default(false)    // Se o jogador zerou a região
  
  score          Int       @default(0)
  totalQuestions Int       @default(0)
  
  startedAt      DateTime  @default(now())
  endedAt        DateTime?
}

// Desempenho individual em cada Pokémon (Para saber os "Mais Acertados" e "Mais Errados")
model PokemonStat {
  id           String @id @default(cuid())
  userId       String
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  pokemonId    Int    // Número da Pokédex (ex: 25 para Pikachu, 6 para Charizard)
  timesSeen    Int    @default(0) // Quantas vezes apareceu para o jogador
  timesCorrect Int    @default(0) // Quantas vezes acertou
  timesWrong   Int    @default(0) // Quantas vezes errou
  
  @@unique([userId, pokemonId]) // Garante apenas 1 registro por Pokémon por usuário
}